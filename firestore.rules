rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // results collection: teacher writes, matched student reads
    match /results/{docId} {
      allow create: if request.auth != null
                    && request.resource.data.teacherId == request.auth.uid
                    && request.resource.data.studentEmail is string;

      allow read: if request.auth != null
                  && (
                    resource.data.teacherId == request.auth.uid
                    || resource.data.studentEmail == request.auth.token.email.lower()
                  );
    }

    // evaluations collection (legacy)
    match /evaluations/{docId} {
      allow read, write: if request.auth != null
                         && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null
                    && request.resource.data.userId == request.auth.uid;
    }

    // scholarships collection (legacy)
    match /scholarships/{docId} {
      allow read, write: if request.auth != null
                         && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null
                    && request.resource.data.userId == request.auth.uid;
    }
  }
}
